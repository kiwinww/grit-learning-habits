generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Child {
  id              Int              @id @default(autoincrement())
  slug            String           @unique
  name            String
  avatar          String
  coinBalance     Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  completions     TaskCompletion[]
  redemptions     Redemption[]
  coinLedgerItems CoinLedger[]
  weeklyReviews   WeeklyReview[]
}

model ScheduleTemplate {
  id        Int             @id @default(autoincrement())
  slug      String          @unique
  name      String
  weekdays  String
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  blocks    ScheduleBlock[]
}

model ScheduleBlock {
  id          Int                     @id @default(autoincrement())
  slug        String                  @unique
  templateId  Int
  taskId      Int?
  startTime   String
  endTime     String
  title       String
  description String
  type        String
  enabled     Boolean                 @default(true)
  sortOrder   Int
  template    ScheduleTemplate        @relation(fields: [templateId], references: [id])
  task        TaskTemplate?           @relation(fields: [taskId], references: [id])
  overrides   DailyScheduleOverride[]
}

model DailyScheduleOverride {
  id          Int            @id @default(autoincrement())
  date        String
  blockId     Int?
  action      String
  startTime   String?
  endTime     String?
  title       String?
  description String?
  type        String?
  taskId      Int?
  sortOrder   Int?
  createdAt   DateTime       @default(now())
  block       ScheduleBlock? @relation(fields: [blockId], references: [id])
}

model TaskTemplate {
  id             Int              @id @default(autoincrement())
  slug           String           @unique
  title          String
  description    String
  points         Int
  enabled        Boolean          @default(true)
  sortOrder      Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completions    TaskCompletion[]
  scheduleBlocks ScheduleBlock[]
}

model TaskCompletion {
  id            Int          @id @default(autoincrement())
  childId       Int
  taskId        Int
  date          String
  completedAt   DateTime     @default(now())
  pointsAwarded Int
  child         Child        @relation(fields: [childId], references: [id])
  task          TaskTemplate @relation(fields: [taskId], references: [id])

  @@unique([childId, taskId, date])
}

model Reward {
  id          Int          @id @default(autoincrement())
  slug        String       @unique
  title       String
  description String
  cost        Int
  tier        String
  category    String
  imageUrl    String?
  enabled     Boolean      @default(true)
  sortOrder   Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  redemptions Redemption[]
}

model Redemption {
  id          Int       @id @default(autoincrement())
  childId     Int
  rewardId    Int
  cost        Int
  status      String
  requestedAt DateTime  @default(now())
  deliveredAt DateTime?
  cancelledAt DateTime?
  child       Child     @relation(fields: [childId], references: [id])
  reward      Reward    @relation(fields: [rewardId], references: [id])
}

model CoinLedger {
  id         Int      @id @default(autoincrement())
  childId    Int
  amount     Int
  reason     String
  sourceType String
  sourceId   Int?
  createdAt  DateTime @default(now())
  child      Child    @relation(fields: [childId], references: [id])
}

model WeeklyReview {
  id          Int      @id @default(autoincrement())
  childId     Int
  weekStart   String
  weekEnd     String
  observation String   @default("")
  nextFocus   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  child       Child    @relation(fields: [childId], references: [id])

  @@unique([childId, weekStart])
}
